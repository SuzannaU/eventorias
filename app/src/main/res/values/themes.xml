<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Eventorias" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:colorBackground">@android:color/black</item>
    </style>

    <style name="Theme.Eventorias.Login" parent="Theme.Eventorias">

        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:colorBackground">@android:color/black</item>

        <!-- General Text colors -->
        <item name="android:textColorPrimary">@android:color/white</item>
        <item name="android:textColorSecondary">@android:color/white</item>
        <item name="android:textColorTertiary">@android:color/white</item>
        <item name="android:editTextColor">@android:color/white</item>
        <item name="android:textColorHint">@android:color/darker_gray</item>
        <item name="android:textColorLink">@color/light_grey</item>

        <!-- Material specific "On" colors (crucial for modern components) -->
        <item name="colorOnSurface">@android:color/white</item>
        <item name="colorOnBackground">@android:color/white</item>
        <item name="colorOnPrimary">@android:color/white</item>

        <!-- Button and accent colors -->
        <item name="colorPrimary">@color/dark_grey</item>
        <item name="colorPrimaryVariant">@color/dark_grey</item>
        <item name="colorSecondary">@color/red</item>
    </style>
</resources>